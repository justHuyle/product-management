mixin table-tree(items, level=1)
    each item, index in items
        -const prefix = Array(level+1).join("-- ")
        tr
            td 
                input(type="checkbox", name="id", value=item.id)
            td #{item.index}
            td 
                if item.thumbnail
                    img(
                        src=(item.thumbnail.startsWith("http") || item.thumbnail.startsWith("/") ? item.thumbnail : `/${item.thumbnail}`)
                        alt=item.title
                    )
            td #{prefix} #{item.title}
            td 
                input(
                    type="number"
                    name="position"
                    value=item.position
                    class="form-control"
                    min="1"
                    style="width:60px"
                )
            td  
                if (item.status == "active")
                    a(class="btn btn-success btn-sm", 
                        button-change-status,
                        href="javascript:;", 
                        current-status=item.status,
                        data-id=item.id
                    ) Hoạt động
                else 
                    a(class="btn btn-danger btn-sm",
                        button-change-status,
                        href="javascript:;", 
                        current-status=item.status,
                        data-id=item.id
                    ) Dừng hoạt động
            td 
                a(href=`${prefixAdmin}/categories/edit/${item.id}`, class="btn btn-warning btn-sm") Sửa
                button(class="btn btn-danger btn-sm" data-id=item.id button-delete) Xóa 
        if (item.children && item.children.length > 0)
            +table-tree(item.children, level + 1)