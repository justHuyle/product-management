extends ../../layouts/default.pug
include ../../mixins/filterStatus.pug
include ../../mixins/pagination.pug
include ../../mixins/formChangeMulti.pug
include ../../mixins/alert.pug
include ../../mixins/sort.pug
include ../../mixins/table-tree.pug
block main
    +alert(3000)
    h1 Trang quản lý danh mục sản phẩm
    .card.mb-3 
        .card-header Danh sách danh mục sản phẩm
        .card-body 
            .row 
                .col-4 
                    a(href=`${prefixAdmin}/categories/create`, class="btn btn-success btn-sm") + Thêm mới 
    div(class="card mb-3")
        .card-header Danh sách danh mục sản phẩm
        .card-body 
            .row 
                .col-4 
                    +sort()
            table(class="table table-hover table-sm" checkbox-multi)
                thead
                    tr
                        th 
                            input(type="checkbox", name="checkall")
                        th STT
                        th Hình ảnh
                        th Tiêu đề
                        th Vị trí
                        th Trạng thái
                        th Hành động
                tbody 
                    +table-tree(categories)
    //- +pagination()
    form(
        action=""
        method="POST"
        id="form-change-status"
        data-path=`${prefixAdmin}/categories/change-status`
    )

    form(
        action=""
        method="POST"
        id="form-delete-item"
        data-path=`${prefixAdmin}/categories/delete`
    )
    //- script(src="/admin/js/product.js")
