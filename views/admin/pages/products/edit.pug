extends ../../layouts/default.pug
include ../../mixins/alert.pug
include ../../mixins/select-tree.pug

block main
    h1 Trang chỉnh sửa sản phẩm 
    +alert(3000)
    form(action=`${prefixAdmin}/products/edit/${product.id}?_method=PATCH`, method="POST", enctype="multipart/form-data") 
        div(class="form-group") 
            label(for="title") Tiêu đề
            input(type="text", name="title", id="title", class="form-control", value=product.title)
        
        div(class="form-group") 
            label(for="categoryId") Danh mục 
            select(name="product_category_id" id="product_category_id" class="form-control")
                option(value="") Chọn danh mục 
                +select-tree(categories, product.product_category_id)
        
        div(class="form-group") 
            label(for="description") Mô tả
            textarea(name="description", id="description", class="form-control", rows="5", value=product.description)
        
        div(class="form-group") 
            label(for="price") Giá
            input(type="text", name="price", id="price", class="form-control", min=0, value=product.price)
        
        div(class="form-group") 
            label(for="discount") Giảm giá
            input(type="number", name="discountPercentage", id="discount", class="form-control", value=product.discountPercentage, min=0, max=100)
        
        div(class="form-group") 
            label(for="stock") Số lượng
            input(type="number", name="stock", id="stock", class="form-control", min=0, value=product.stock)
        
        div(class="form-group" upload-image) 
            label(for="thumbnail") Hình ảnh
            input(type="file", name="thumbnail", id="thumbnail", class="form-control-file" accept="image/*" upload-image-input)
            img(src=`${product.thumbnail}` upload-image-preview class="image-preview")
            button(type="button" class="btn btn-danger mt-3 clear-image" clear-image) Xóa ảnh
        
        div(class="form-group") 
            label(for="position") Vị trí
            input(type="number", name="position", id="position", class="form-control", value=product.position, min=1)
        
        div(class="form-group") 
            label(for="status") Trạng thái
            select(name="status", id="status", class="form-control")
                option(value="active", selected=(product.status !== "inactive") ? true : false) Hoạt động    
                option(value="inactive", selected=(product.status !== "active") ? true : false) Dừng hoạt động
        button(type="submit", class="btn btn-primary") Lưu
    
    script(src="/admin/js/product.js")